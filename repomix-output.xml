"use client";

import { useState, type FormEvent } from "react";

type Status = "idle" | "sending" | "success" | "error";

export default function Contato() {
  const [status, setStatus] = useState<Status>("idle");

  const handleSubmit = (e: FormEvent<HTMLFormElement>) => {
    e.preventDefault();
    setStatus("sending");

    const form = e.currentTarget;
    const data = new FormData(form);

    fetch("https://formspree.io/f/placeholder", {
      method: "POST",
      body: data,
      headers: { Accept: "application/json" },
    })
      .then((res) => {
        if (res.ok) {
          setStatus("success");
          form.reset();
        } else {
          setStatus("error");
        }
      })
      .catch(() => setStatus("error"));
  };

  return (
    <section id="contato" className="bg-bg px-6 py-20 lg:px-12 lg:py-28">
      <div className="mx-auto max-w-6xl">
        <div className="mb-14 lg:mb-20">
          <h2 className="mb-4 font-serif text-[clamp(2rem,4vw+0.5rem,3.5rem)] font-semibold leading-[1.1] tracking-[-0.02em] text-ink-rich [text-wrap:balance]">
            Entre em contato
          </h2>
          <p className="max-w-[62ch] text-lg leading-relaxed text-muted lg:text-xl">
            Preencha o formulário ou fale diretamente conosco pelo WhatsApp.
            Retornaremos em breve.
          </p>
        </div>

        <div className="grid gap-10 lg:grid-cols-[1fr_360px] lg:gap-16">
      <form
        onSubmit={handleSubmit}
        noValidate
        className="flex flex-col gap-6"
      >
            <div className="grid gap-6 sm:grid-cols-2">
              <label className="flex flex-col gap-1.5">
                <span className="text-sm font-medium text-ink">
                  Nome <span aria-hidden="true" className="text-error">*</span>
                </span>
                <input
                  type="text"
                  name="nome"
                  required
                  placeholder="Seu nome completo"
                  className="h-12 rounded-lg border border-border bg-bg px-4 text-base text-ink placeholder:text-muted-light transition-colors hover:border-border-strong focus:border-primary focus:ring-0 focus:outline-none focus-visible:border-primary"
                />
              </label>
              <label className="flex flex-col gap-1.5">
                <span className="text-sm font-medium text-ink">
                  Email ou telefone{" "}
                  <span aria-hidden="true" className="text-error">*</span>
                </span>
                <input
                  type="text"
                  name="contato"
                  required
                  placeholder="seu@email.com ou (00) 00000-0000"
                  className="h-12 rounded-lg border border-border bg-bg px-4 text-base text-ink placeholder:text-muted-light transition-colors hover:border-border-strong focus:border-primary focus:ring-0 focus:outline-none focus-visible:border-primary"
                />
              </label>
            </div>
            <label className="flex flex-col gap-1.5">
              <span className="text-sm font-medium text-ink">
                Mensagem{" "}
                <span aria-hidden="true" className="text-error">*</span>
              </span>
              <textarea
                name="mensagem"
                required
                rows={5}
                placeholder="Descreva brevemente seu caso ou dúvida"
                className="resize-y rounded-lg border border-border bg-bg px-4 py-3 text-base text-ink placeholder:text-muted-light transition-colors hover:border-border-strong focus:border-primary focus:ring-0 focus:outline-none focus-visible:border-primary"
              />
            </label>

            <button
              type="submit"
              disabled={status === "sending"}
              className="inline-flex h-12 w-fit items-center rounded-full bg-primary px-10 text-sm font-semibold text-white transition-all duration-300 hover:bg-primary-deep focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white disabled:opacity-60"
            >
              {status === "sending" ? (
                <span className="flex items-center gap-2">
                  <svg
                    className="h-4 w-4 animate-spin"
                    viewBox="0 0 24 24"
                    fill="none"
                    aria-hidden="true"
                  >
                    <circle
                      cx="12"
                      cy="12"
                      r="10"
                      stroke="currentColor"
                      strokeWidth="3"
                      className="opacity-25"
                    />
                    <path
                      d="M4 12a8 8 0 018-8"
                      stroke="currentColor"
                      strokeWidth="3"
                      strokeLinecap="round"
                      className="opacity-75"
                    />
                  </svg>
                  Enviando…
                </span>
              ) : (
                "Enviar mensagem"
              )}
            </button>

            {status === "success" && (
              <div
                role="status"
                className="rounded-lg border border-success/30 bg-success/8 px-5 py-4 text-base text-success"
              >
                Mensagem enviada com sucesso. Retornaremos em breve.
              </div>
            )}
            {status === "error" && (
              <div
                role="alert"
                className="rounded-lg border border-error/30 bg-error/8 px-5 py-4 text-base text-error"
              >
                Não foi possível enviar. Tente novamente ou fale conosco
                pelo WhatsApp.
              </div>
            )}
          </form>

          <aside className="flex flex-col gap-8 rounded-xl bg-surface p-8 lg:p-10">
